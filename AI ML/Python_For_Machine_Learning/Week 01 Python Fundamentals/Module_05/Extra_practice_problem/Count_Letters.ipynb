   "source": [
    "n = input()\n",
    "cnt = [0]*26\n",
    "for s in n:\n",
    "        cnt[ord(s) - ord('a')] += 1\n",
    "for i in range(26):\n",
    "    if cnt[i] > 0:\n",
    "        print(f\"{chr(i+ord('a'))} : {cnt[i]}\")\n",
    "        "
   ]

   "source": [
    "inp = int(input())\n",
    "cnt1= 0; cnt2 = 0\n",
    "for i in range(inp):\n",
    "    vote = input()\n",
    "    if vote == \"YES\":\n",
    "        cnt1 += 1\n",
    "    else:\n",
    "        cnt2 += 1\n",
    "if(cnt1>=cnt2):\n",
    "    print(\"ACCEPT\")\n",
    "else:\n",
    "    print(\"REJECT\")"
   ]
  }

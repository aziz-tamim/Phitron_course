   "source": [
    "# using Reduce\n",
    "\n",
    "from functools import reduce\n",
    "\n",
    "n = int(input())\n",
    "\n",
    "arr = list(map(float, input().split()))\n",
    "summation = reduce(lambda x,y : x+y, arr)\n",
    "div = summation/n\n",
    "\n",
    "print(f\"{div:.6f}\")"
   ]
